# =========================
# App Configuration
# =========================
APP_NAME="Invoice System API"
ENVIRONMENT=development
API_V1_STR=/api/v1

# =========================
# PostgreSQL Configuration
# =========================
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_database_name
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy Database URL (using asyncpg for async PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/invoice_db

# JWT Authentication
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Optional - Full database URL
DATABASE_URL=postgresql://user:password@localhost:5432/db_name

# =========================
# SMTP / Email Configuration
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME="Invoice System"
